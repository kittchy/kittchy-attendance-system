{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kittchy-attendance",
  "version": "0.4.0",
  "identifier": "com.kittchy.attendance",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "cwd": "../frontend", "script": "npm run dev -- --host" },
    "beforeBuildCommand": { "cwd": "../frontend", "script": "npm run build" }
  },
  "app": {
    "windows": [
      {
        "title": "Kittchy 勤怠管理",
        "width": 480,
        "height": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
